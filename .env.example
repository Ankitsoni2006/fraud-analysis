# IVC Operational Risk Intelligence Platform Config
# =================================================

# Database configuration (Defaults to local SQLite fallback if unset)
DATABASE_URL=postgresql://ivc_user:ivc_pass@localhost:5432/ivc_db

# Active mode (SIMULATION runs synthetic data generator, REAL_DATA reads ingested logs)
IVC_MODE=SIMULATION

# ── Tunable Detection Thresholds ──────────────────────────────────────────────
# Physical speed cap: anything above is physically impossible for a human (m/s)
IVC_MAX_HUMAN_SPEED_MS=6.0

# Sigma standard deviations multiplier for hesitation detection
IVC_HESITATION_SIGMA=2.5

# High-value item threshold (INR value)
IVC_HIGH_VALUE_INR=300

# Packer risk leaderboard weights
IVC_TYPE_A_WEIGHT=3
IVC_TYPE_B_WEIGHT=2

# Risk tier thresholds for packer leaders
IVC_RISK_CRITICAL=10
IVC_RISK_HIGH=5
